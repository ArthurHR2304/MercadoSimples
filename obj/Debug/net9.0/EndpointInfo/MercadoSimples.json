            "minimum": 0,01,
            "type": "number",
            "format": "double"
          },
          "valorEstoque": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "validade": {
            "type": "string",
            "format": "date-time"
          },
          "ativo": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
